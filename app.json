{
  "expo": {
    "name": "Vault Deck",
    "slug": "vault-deck",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "vaultdeck",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F0F"
      },
      "package": "com.vaultdeck.app"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
