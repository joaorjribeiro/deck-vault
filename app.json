{
  "expo": {
    "name": "Deck Vault",
    "slug": "deck-vault",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "deckvault",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#120B14"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#120B14"
      },
      "package": "com.deckvault.app"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
